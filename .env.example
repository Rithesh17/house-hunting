# Copy this file to ".env" and fill in your values.
# Create a bot with @BotFather on Telegram to get the token.
# Get your chat id by messaging your bot then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# (or message @userinfobot).

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Base URL of the local dashboard, used in Telegram links.
DASHBOARD_URL=http://localhost:8000

# Supabase (cloud DB behind the public dashboard). Get these from
#   supabase projects api-keys --project-ref <ref>
# anon key is public-safe (RLS allows SELECT only); service_role is SECRET and
# used only by scripts/sync_supabase.py to publish the local DB to the cloud.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Public dashboard URL (Vercel production alias), shown in Telegram links.
VERCEL_DASHBOARD_URL=
