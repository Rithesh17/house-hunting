<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Every-4-hours house-hunting refresh (headless Claude Code). Zillow gated once/day.
  NOTE: launchd cannot EXEC a script from the external volume (/Volumes/...) — macOS
  TCC returns "Operation not permitted" (exit 126). So the wrapper is installed to
  the INTERNAL disk (~/.househunt/daily_refresh.sh); it cd's into the project on the
  external volume to do the work. scripts/daily_refresh.sh is the source of truth.
  Install / reinstall:
    mkdir -p ~/.househunt
    cp scripts/daily_refresh.sh ~/.househunt/daily_refresh.sh && chmod +x ~/.househunt/daily_refresh.sh
    cp ops/com.rithesh.househunt.refresh.plist ~/Library/LaunchAgents/
    launchctl bootout  gui/$(id -u)/com.rithesh.househunt.refresh 2>/dev/null
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.rithesh.househunt.refresh.plist
  Inspect:  launchctl print gui/$(id -u)/com.rithesh.househunt.refresh
  Run now:  launchctl kickstart -k gui/$(id -u)/com.rithesh.househunt.refresh
  Remove:   launchctl bootout gui/$(id -u)/com.rithesh.househunt.refresh && rm ~/Library/LaunchAgents/com.rithesh.househunt.refresh.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.rithesh.househunt.refresh</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/rithesh/.househunt/daily_refresh.sh</string>
  </array>
  <!-- Every 4 hours (01,05,09,13,17,21). Zillow is gated to once/calendar-day in
       refresh.py, so only the day's first run pulls it; Craigslist + Zumper (free)
       refresh each run. notify uses --quiet-if-empty so only real picks ping. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>1</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>5</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>21</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key>
  <string>/Users/rithesh/Library/Logs/house-hunting-refresh.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/rithesh/Library/Logs/house-hunting-refresh.err.log</string>
  <key>RunAtLoad</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
